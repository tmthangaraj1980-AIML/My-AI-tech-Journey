#Leetcode sum two sum II - 167
def two_sum_sorterd(num, target):
  l= 0
  r = len(num) - 1

  while l < r:
    two_sum = num[l] + num[r]
    if two_sum == target:
      return[l+1, r+1]
    elif two_sum > target:
      r -= 1
    else:
      l += 1
num = list(map(int, input("Enter the numbers (space separated):").split()))
target = int(input("Enter the target:"))
two_sum_sorterd(num, target)
