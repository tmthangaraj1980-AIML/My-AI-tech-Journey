#Leetcode sum two sum II - 167(In google colab by get the inputs from user)
def two_sum_sorterd(num, target):
  l= 0
  r = len(num) - 1

  while l < r:
    two_sum = num[l] + num[r]
    if two_sum == target:
      return[l+1, r+1]
    elif two_sum > target:
      r -= 1
    else:
      l += 1
num = list(map(int, input("Enter the numbers (space separated):").split()))
target = int(input("Enter the target:"))
two_sum_sorterd(num, target)


LEETCODE PLATFORM
class Solution:
    def twoSum(self, numbers: List[int], target: int) -> List[int]:
        l= 0
        r = len(numbers) - 1

        while l < r:
            two_sum = numbers[l] + numbers[r]
            if two_sum == target:
                return[l+1, r+1]
            elif two_sum > target:
                r -= 1
            else:
                l += 1
